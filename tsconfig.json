{
  "compilerOptions": {
    "module": "commonjs",
    "target": "es2015",
    "isolatedModules": true,
    "noEmit": true, 
    "skipLibCheck": true,
    "experimentalDecorators": true,
    "strictNullChecks": true,
    "allowJs": true,
    "lib": ["es2015"],
    "types": [],
    "baseUrl": "./Assets"
  },
  "include": [
    "Library/CompiledScripts/Types/**/*.d.ts",
    "Assets/**/*.ts"
  ]
}